# Terraform state files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform plan files
*.tfplan

# Terraform working directory
.terraform/
.terraform.lock.hcl

# Variable files that may contain sensitive data
*.tfvars
!terraform.tfvars.example

# Crash log files
crash.log
crash.*.log

# Override files (local developer settings)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI config file
.terraformrc
terraform.rc
